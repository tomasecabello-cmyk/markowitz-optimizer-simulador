# Copiá este archivo a .env y completá la clave para activar el análisis con IA real.
# Sin la clave, el endpoint de IA devuelve un análisis mock determinístico.
ANTHROPIC_API_KEY=

# Modelo de Claude a usar (por defecto: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Datos de mercado (todo sin key) ---
# US: yfinance. ARG acciones/CEDEARs/bonos soberanos: data912. ONs: Rava Bursátil.
# Tipo de cambio USD/ARS (normalización): argentinadatos (CCL/MEP/...).
#
# PPI es OPCIONAL: solo se usa como respaldo de histórico de ONs si Rava falla.
PPI_API_KEY=
PPI_API_SECRET=
